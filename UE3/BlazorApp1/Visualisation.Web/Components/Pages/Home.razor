@page "/"
@rendermode InteractiveServer
@using BlazorApp1.Services
@inject SerialService Serial

<div class="dashboard">
    <header class="dashboard-header">
        <h1 class="dashboard-title">Messomat Prozessvisualisierung</h1>
        <p class="dashboard-subtitle">Echtzeit-Sensorüberwachung über serielle Schnittstelle</p>
    </header>

    <section class="connection-section dashboard-card">
        <h2 class="section-title">Verbindung</h2>
        <div class="connection-status-row">
            <span class="status-indicator @(Serial.IsConnected ? "status-connected" : "status-disconnected")" title="@(Serial.IsConnected ? "Verbunden" : "Getrennt")"></span>
            <span class="status-text">@(Serial.IsConnected ? "Verbunden mit " + _selectedPort : "Nicht verbunden")</span>
        </div>
        @if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="connection-error">
                <span class="connection-error-icon">⚠</span>
                <span>@_errorMessage</span>
                <button type="button" class="connection-error-dismiss" @onclick="() => { _errorMessage = string.Empty; StateHasChanged(); }" aria-label="Schließen">×</button>
            </div>
        }
        <div class="connection-controls">
            <div class="control-group">
                <label for="port-select" class="control-label">COM-Port</label>
                <select id="port-select" class="form-select" @bind="_selectedPort" disabled="@Serial.IsConnected">
                    @foreach (var p in _ports)
                    {
                        <option value="@p">@p</option>
                    }
                </select>
            </div>
            <div class="control-group">
                <label class="control-label">&nbsp;</label>
                @if (Serial.IsConnected)
                {
                    <button class="btn btn-outline-danger" @onclick="Disconnect">
                        Trennen
                    </button>
                }
                else
                {
                    <button class="btn btn-primary" @onclick="Connect">
                        <span class="btn-icon">⚡</span> Verbinden
                    </button>
                }
            </div>
            <div class="control-group control-group-checkbox">
                <label class="checkbox-label">
                    <input type="checkbox" class="form-check-input" @bind="_ackEnabled"/>
                    <span>ACK senden</span>
                </label>
            </div>
        </div>
        @if (Serial.IsConnected && !_ackEnabled)
        {
            <div class="connection-warning">
                <span class="connection-warning-icon">ℹ</span>
                <span>ACK ist deaktiviert – das Arduino stoppt nach 3 fehlgeschlagenen Versuchen das Senden.</span>
            </div>
        }
        @if (Serial.IsConnected)
        {
            <div class="arduino-commands">
                <span class="control-label">Arduino-Befehle:</span>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SendCommand('r')" title="Senden starten (Reset nach Fehler)">r</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SendCommand('d')" title="Sofort senden + starten">d</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SendCommand('1')" title="Intervall 1 Sekunde">1</button>
                <button type="button" class="btn btn-sm btn-outline-secondary" @onclick="() => SendCommand('4')" title="Intervall 4 Sekunden">4</button>
                <span class="command-hint">(r=durchstarten wenn gestoppt)</span>
            </div>
        }
    </section>

    <div class="dashboard-grid">
        <section class="dashboard-card messages-card">
            <h2 class="section-title">Empfangene Nachrichten</h2>
            <div class="messages-log">
                @if (_messages.Count == 0)
                {
                    <p class="messages-empty">Warte auf Daten...</p>
                }
                else
                {
                    @foreach (var m in _messages)
                    {
                        <div class="message-line" title="@FormatMessageForTooltip(m)">@FormatMessageForDisplay(m)</div>
                    }
                }
            </div>
        </section>

        <section class="dashboard-card values-card">
            <h2 class="section-title">Letzte Werte</h2>
            <div class="sensor-values">
                <div class="sensor-item">
                    <span class="sensor-label">Temperatur</span>
                    <span class="sensor-value">@_temperature</span>
                    <span class="sensor-unit">°C</span>
                </div>
                <div class="sensor-item">
                    <span class="sensor-label">Feuchtigkeit</span>
                    <span class="sensor-value">@_humidity</span>
                    <span class="sensor-unit">%</span>
                </div>
                <div class="sensor-item">
                    <span class="sensor-label">Sequence-Nummer</span>
                    
                </div>
            </div>
        </section>
    </div>
</div>

<style>
    .dashboard {
        max-width: 1200px;
        margin: 0 auto;
    }

    .dashboard-header {
        margin-bottom: 2rem;
    }

    .dashboard-title {
        font-size: 1.75rem;
        font-weight: 700;
        margin: 0 0 0.25rem 0;
        background: linear-gradient(135deg, var(--color-text), var(--color-accent));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
    }

    .dashboard-subtitle {
        color: var(--color-text-muted);
        font-size: 0.95rem;
        margin: 0;
    }

    .connection-section {
        margin-bottom: 1.5rem;
    }

    .connection-status-row {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-bottom: 1rem;
    }

    .status-indicator {
        width: 10px;
        height: 10px;
        border-radius: 50%;
        flex-shrink: 0;
        animation: status-pulse 2s ease-in-out infinite;
    }

    .status-connected {
        background: var(--color-success);
        box-shadow: 0 0 8px var(--color-success);
    }

    .status-disconnected {
        background: var(--color-text-muted);
    }

    @@keyframes status-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.6; }
    }

    .status-text {
        font-size: 0.9rem;
        color: var(--color-text-muted);
    }

    .status-connected + .status-text {
        color: var(--color-success);
    }

    .connection-error {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        background: rgba(248, 113, 113, 0.15);
        border: 1px solid var(--color-danger);
        border-radius: var(--radius-sm);
        color: var(--color-danger);
        font-size: 0.9rem;
    }

    .connection-error-icon {
        flex-shrink: 0;
    }

    .connection-error-dismiss {
        margin-left: auto;
        background: none;
        border: none;
        color: inherit;
        font-size: 1.25rem;
        cursor: pointer;
        padding: 0 0.25rem;
    }

    .connection-error-dismiss:hover {
        opacity: 0.8;
    }

    .connection-warning {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1rem;
        margin-bottom: 1rem;
        background: rgba(251, 191, 36, 0.15);
        border: 1px solid var(--color-warning);
        border-radius: var(--radius-sm);
        color: var(--color-warning);
        font-size: 0.9rem;
    }

    .connection-warning-icon {
        flex-shrink: 0;
    }

    .btn-outline-danger {
        background: transparent;
        border: 1px solid var(--color-danger);
        color: var(--color-danger);
    }

    .btn-outline-danger:hover {
        background: var(--color-danger);
        color: white;
    }

    .arduino-commands {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem;
        margin-top: 1rem;
        padding-top: 1rem;
        border-top: 1px solid var(--color-border);
    }

    .arduino-commands .btn-sm {
        min-width: 2rem;
    }

    .command-hint {
        font-size: 0.75rem;
        color: var(--color-text-muted);
    }

    .btn-outline-secondary {
        background: transparent;
        border: 1px solid var(--color-border);
        color: var(--color-text-muted);
    }

    .btn-outline-secondary:hover {
        background: var(--color-surface-hover);
        color: var(--color-text);
    }

    .section-title {
        font-size: 1rem;
        font-weight: 600;
        color: var(--color-text-muted);
        margin: 0 0 1rem 0;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .connection-controls {
        display: flex;
        flex-wrap: wrap;
        gap: 1rem;
        align-items: flex-end;
    }

    .control-group {
        display: flex;
        flex-direction: column;
        gap: 0.35rem;
    }

    .control-label {
        font-size: 0.8rem;
        color: var(--color-text-muted);
    }

    .control-group .form-select {
        min-width: 180px;
    }

    .control-group-checkbox {
        justify-content: flex-end;
    }

    .checkbox-label {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        cursor: pointer;
        color: var(--color-text-muted);
        font-size: 0.9rem;
    }

    .checkbox-label:hover {
        color: var(--color-text);
    }

    .btn-icon {
        margin-right: 0.35rem;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
    }

    @@media (max-width: 768px) {
        .dashboard-grid {
            grid-template-columns: 1fr;
        }
    }

    .messages-card {
        min-height: 280px;
    }

    .messages-log {
        height: 220px;
        overflow-y: auto;
        padding: 1rem;
        background: rgba(0, 0, 0, 0.2);
        border-radius: var(--radius-sm);
        border: 1px solid var(--color-border);
        font-family: 'Consolas', 'Monaco', monospace;
        font-size: 0.85rem;
    }

    .messages-empty {
        color: var(--color-text-muted);
        margin: 0;
    }

    .message-line {
        padding: 0.2rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
        word-break: break-all;
    }

    .message-line:last-child {
        border-bottom: none;
    }

    .sensor-values {
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .sensor-item {
        display: flex;
        align-items: baseline;
        gap: 0.5rem;
        padding: 1rem;
        background: rgba(0, 0, 0, 0.2);
        border-radius: var(--radius-sm);
        border-left: 4px solid var(--color-accent);
    }

    .sensor-label {
        color: var(--color-text-muted);
        font-size: 0.9rem;
        min-width: 100px;
    }

    .sensor-value {
        font-size: 2rem;
        font-weight: 700;
        color: var(--color-accent);
    }

    .sensor-unit {
        color: var(--color-text-muted);
        font-weight: 500;
    }
</style>

@implements IDisposable

@code {

    List<string> _ports = new();
    string _selectedPort = "";

    readonly List<string> _messages = new();

    string _errorMessage = "";

    bool _ackEnabled = true;

    int _temperature;
    int _humidity;

    protected override void OnInitialized()
    {
        _ports = Serial.GetAvailablePorts();

        if (_ports.Count > 0)
            _selectedPort = _ports[0];

        Serial.MessageReceived += OnMessage;
        Serial.ConnectionStateChanged += OnConnectionStateChanged;
    }

    void OnConnectionStateChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    async Task Connect()
    {
        _errorMessage = "";

        try
        {
            await Serial.ConnectAsync(_selectedPort);
        }
        catch (UnauthorizedAccessException)
        {
            _errorMessage = $"Port {_selectedPort} wird bereits von einem anderen Programm verwendet.";
        }
        catch (System.IO.IOException ex)
        {
            _errorMessage = $"Kein Gerät an {_selectedPort} angeschlossen oder Port nicht verfügbar: {ex.Message}";
        }
        catch (InvalidOperationException ex)
        {
            _errorMessage = $"Port {_selectedPort} ist nicht verfügbar: {ex.Message}";
        }
        catch (Exception ex)
        {
            _errorMessage = $"Verbindungsfehler: {ex.Message}";
        }

        StateHasChanged();
    }

    async Task Disconnect()
    {
        await Serial.DisconnectAsync();
    }

    void SendCommand(char cmd)
    {
        Serial.Send(cmd.ToString());
    }

    /// <summary>Formatiert eine Nachricht für die Anzeige - Steuerzeichen werden als $XX (Hex) dargestellt.</summary>
    static string FormatMessageForDisplay(string msg)
    {
        var sb = new System.Text.StringBuilder();
        foreach (char c in msg)
        {
            if (char.IsControl(c) || c < 32 || c > 126)
                sb.Append('$').Append(((int)c).ToString("X2"));
            else
                sb.Append(c);
        }
        return sb.ToString();
    }

    /// <summary>Original-Nachricht für Tooltip (mit Hex-Codes für Steuerzeichen).</summary>
    static string FormatMessageForTooltip(string msg)
    {
        var formatted = FormatMessageForDisplay(msg);
        return formatted != msg ? $"{msg} (Anzeige: {formatted})" : msg;
    }

    void OnMessage(string msg)
    {
        InvokeAsync(() =>
        {
            _messages.Add(msg);

            var data = MessageParser.Parse(msg);

            _temperature = data.Temperature;
            _humidity = data.Humidity;

            Serial.AckEnabled = _ackEnabled;

            if (_messages.Count > 50)
                _messages.RemoveAt(0);

            StateHasChanged();
        });
    }

    public void Dispose()
    {
        Serial.MessageReceived -= OnMessage;
        Serial.ConnectionStateChanged -= OnConnectionStateChanged;
    }

}
